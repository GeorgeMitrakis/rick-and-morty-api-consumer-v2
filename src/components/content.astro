---
import Container from "../layouts/container.astro";
import CharacterGrid from "./character-grid.vue";
---

<div class="characters-section">
    <Container class="characters-area" style="--maxWidth:1252px">
        <CharacterGrid client:load />
    </Container>
</div>
<style>
    .characters-section {
        min-height: 636px;
        background-image: url("/assets/characters-area-background.png");
        background-repeat: no-repeat;
        background-position: center;
        background-size: cover;
        background-color: #03b0c8;
        display: flex;
        flex-direction: column;
    }

    .characters-area {
        padding-block: 16px;
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        gap: 16px;
    }
</style>
