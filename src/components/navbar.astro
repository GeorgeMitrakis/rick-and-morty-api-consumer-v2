---
import Logo from "../../assets/rick-face.svg";
---

<nav class="navbar">
    <a href="/" class="logo">
        <Logo />
    </a>
</nav>

<style>
    .navbar {
        width: 100%;
        padding: 0;
        display: flex;
        position: absolute;
        top: 0;
    }

    .logo {
        padding: 8px;
        border-radius: 2px;
    }

    .logo svg {
        width: auto;
        height: 48px;
    }

    .logo:hover {
        box-shadow: inset 0 0 10px 1px lime;
    }
</style>
